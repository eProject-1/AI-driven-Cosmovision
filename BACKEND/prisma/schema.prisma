generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  username           String             @unique
  passwordHash       String?
  displayName        String?
  avatarUrl          String?
  role               Role               @default(USER)
  provider           Provider           @default(LOCAL)
  providerId         String?
  isVerified         Boolean            @default(false)
  verificationToken  String?            @unique
  isActive           Boolean            @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  analytics          Analytics[]
  chatSessions       ChatSession[]
  imageUploads       ImageUpload[]
  recommendations    Recommendation[]
  refreshTokens      RefreshToken[]
  savedEvents        SavedEvent[]
  savedObservatories SavedObservatory[]
  preferences        UserPreference?
  profile            UserProfile?

  @@map("users")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?
  location  String?
  latitude  Float?
  longitude Float?
  timezone  String?  @default("UTC")
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserPreference {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  favoritesPlanets        String[] @default([])
  favoritesConstellations String[] @default([])
  experienceLevel         String   @default("beginner")
  emailAlerts             Boolean  @default(true)
  eventReminders          Boolean  @default(true)
  temperatureUnit         String   @default("celsius")
  distanceUnit            String   @default("km")
  timeFormat              String   @default("24h")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Planet {
  id String @id @default(cuid())

  name String @unique
  slug String @unique

  type        String
  description String

  imageUrl String?

  massKg     Float?
  diameterKm Float?
  gravityMs2 Float?

  distanceFromSunAu   Float?
  distanceFromEarthKm Float?

  orbitalPeriodDays   Float?
  rotationPeriodHours Float?

  avgTempCelsius Float?

  atmosphere String[] @default([])

  numberOfMoons Int?    @default(0)
  hasRings      Boolean @default(false)

  discoveredBy  String?
  discoveryYear Int?

  aiFunFacts String[] @default([])
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("planets")
}

model Constellation {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  // ── Định danh thiên văn ──────────────────────────────────
  latinName    String?
  abbreviation String? // VD: "Ori", "UMa"
  family       String? // VD: "Orion", "Ursa Major"
  quadrant     String? // VD: "NQ1", "SQ2"

  // ── Toạ độ thiên cầu ────────────────────────────────────
  rightAscension   String? // VD: "5h 30m"
  declination      String? // VD: "+0°"
  areaSqDeg        Float? // Diện tích (độ vuông)
  visibleLatitudes String? // VD: "+90° to -75°"

  // ── Quan sát ─────────────────────────────────────────────
  mainStars     Int? // Số sao chính
  brightestStar String? // Tên sao sáng nhất
  bestMonth     String? // Tháng tốt nhất (VD: "January")
  bestSeason    String? // Mùa tốt nhất (VD: "Winter")

  // ── Media & mô tả ────────────────────────────────────────
  images             ImageUpload[]
  imageUrl           String?
  mapUrl             String? // URL ảnh bản đồ sao
  description        String?
  mythologicalOrigin String?

  // ── AI-generated content (cached) ────────────────────────
  aiMythology   String?
  aiFacts       String[] @default([])
  aiObserverTip String?

  // ── Flags ────────────────────────────────────────────────
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("constellations")
}

model CelestialEvent {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  type        EventType
  description String
  details     String?
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime?
  peakDate    DateTime?
  visibleFrom String[]     @default([])
  latitude    Float?
  aiSummary   String?
  isRecurring Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  savedBy     SavedEvent[]

  @@index([startDate])
  @@map("celestial_events")
}

model SavedEvent {
  id      String         @id @default(cuid())
  userId  String
  eventId String
  savedAt DateTime       @default(now())
  event   CelestialEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("saved_events")
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  role       String
  content    String
  intent     IntentType  @default(UNKNOWN)
  tokensUsed Int?
  modelUsed  String?     @default("llama-3.1-8b-instant")
  createdAt  DateTime    @default(now())
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

model NewsArticle {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  source      String
  sourceUrl   String
  imageUrl    String?
  publishedAt DateTime
  category    NewsCategory @default(GENERAL)
  summary     String?
  tags        String[]     @default([])
  fetchedAt   DateTime     @default(now())
  createdAt   DateTime     @default(now())

  @@index([publishedAt])
  @@index([category])
  @@map("news_articles")
}

model Recommendation {
  id                    String    @id @default(cuid())
  userId                String
  latitude              Float
  longitude             Float
  locationKey           String? // NEW — cache key: "21.03_105.85"
  locationName          String?
  requestedAt           DateTime  @default(now())
  weatherCondition      String?
  temperature           Float?
  humidity              Float?
  skyVisibilityScore    Int?
  bestTimeStart         DateTime?
  bestTimeEnd           DateTime?
  visiblePlanets        String[]  @default([])
  visibleConstellations String[]  @default([])
  nearbyObservatories   String[]  @default([]) // NEW — slug[] của observatory gần đó
  aiSuggestion          String?
  expiresAt             DateTime? // NEW — TTL cho recommendation cache (30 phút)
  createdAt             DateTime  @default(now())
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([requestedAt])
  @@index([locationKey, expiresAt]) // NEW — tăng tốc tìm cache còn hạn
  @@map("recommendations")
}

model Observatory {
  id String @id @default(cuid())

  name String @unique
  slug String @unique

  description String

  type ObservatoryType @default(PUBLIC)

  latitude  Float
  longitude Float

  address  String
  city     String
  province String
  country  String @default("Vietnam")

  elevation Float?

  website String?
  phone   String?
  email   String?

  imageUrl String?

  equipment String[] @default([])

  openingHours String?

  // Recommendation fields
  rating      Float? @default(0)
  reviewCount Int    @default(0)

  lightPollutionScore Float?
  skyQualityScore     Float?

  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedBy SavedObservatory[]

  @@index([latitude, longitude])
  @@index([province])
  @@map("observatories")
}

model SavedObservatory {
  id String @id @default(cuid())

  userId        String
  observatoryId String

  savedAt DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  observatory Observatory @relation(fields: [observatoryId], references: [id], onDelete: Cascade)

  @@unique([userId, observatoryId])
  @@index([userId])
  @@index([observatoryId])
  @@map("saved_observatories")
}

enum ObservatoryType {
  PUBLIC
  PRIVATE
  UNIVERSITY
}

model ImageUpload {
  id                      String         @id @default(cuid())
  userId                  String
  originalUrl             String
  fileName                String
  fileSize                Int
  mimeType                String
  isProcessed             Boolean        @default(false)
  recognizedConstellation String?
  constellationId         String?
  confidenceScore         Float?
  aiAnalysis              String?
  processedAt             DateTime?
  createdAt               DateTime       @default(now())
  constellation           Constellation? @relation(fields: [constellationId], references: [id])
  user                    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("image_uploads")
}

model Analytics {
  id         String         @id @default(cuid())
  userId     String?
  event      AnalyticsEvent
  entityType String?
  entityId   String?
  entityName String?
  ipAddress  String?
  userAgent  String?
  referrer   String?
  metadata   Json?
  createdAt  DateTime       @default(now())
  user       User?          @relation(fields: [userId], references: [id])

  @@index([event])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics")
}

enum Role {
  USER
  ADMIN
}

enum Provider {
  LOCAL
  GOOGLE
  GITHUB
}

enum IntentType {
  PLANET_INFO
  CONSTELLATION_INFO
  STARGAZING_RECOMMENDATION
  WEATHER_CHECK
  OBSERVATORY_SEARCH
  GENERAL_ASTRONOMY
  NEWS
  GUIDE
  IMAGE_RECOGNITION
  FAVORITE
  UNKNOWN
}

enum NewsCategory {
  SPACE_EXPLORATION
  SOLAR_SYSTEM
  DEEP_SPACE
  TECHNOLOGY
  GENERAL
}

enum EventType {
  METEOR_SHOWER
  ECLIPSE
  PLANET_OPPOSITION
  CONJUNCTION
  SUPERMOON
  COMET
  OTHER
}

enum AnalyticsEvent {
  PAGE_VIEW
  PLANET_VIEW
  CONSTELLATION_VIEW
  CHATBOT_MESSAGE
  NEWS_VIEW
  RECOMMENDATION_REQUEST
  OBSERVATORY_VIEW
  IMAGE_UPLOAD
  SEARCH
}

model WeatherCache {
  id         String @id @default(cuid())
  latRounded Float
  lonRounded Float

  condition   String
  label       String
  temperature Float
  feelsLike   Float?
  humidity    Float
  cloudCover  Float
  windSpeed   Float
  visibility  Float
  description String?
  cityName    String?
  countryCode String?
  sunrise     DateTime?
  sunset      DateTime?

  fetchedAt DateTime
  expiresAt DateTime

  @@unique([latRounded, lonRounded], name: "latRounded_lonRounded")
  @@index([expiresAt])
  @@map("weather_cache")
}
